#To intersect the multicoverage result with refseq_transcripts.It takes only the unique parts from file1 and does not print the refseq information.
bedtools intersect -a multicov_up_instances.txt -b refseq_transcripts.bed -wa -wb -u >TE_unique.bed

#taking intersect for unique.bed with refseq information, now it prints the refseq information as -u is not present.
bedtools intersect -a TE_unique.bed -b refseq_transcripts.bed -wa -wb >TE_unique1.bed

#prints a file with only the required columns.
awk '{print $1,$2,$3,$4,$7,$8,$9,$10,$11,$12,$13,$14}' OFS='\t' TE_unique1.bed | sort -u > TE_unique_pairs.bed

#to extract rows which only contain th TE familes we require.(TE.txt has TEfamilies which we require, that was given by TEtranscripts)
awk 'NR==FNR {a[$1]; next} $4 in a' TE.txt TE_unique1.bed > TE_filtered.bed

#remove rows which have count=0 in row5,6,7, and 8.
awk '!($5==0 && $6==0 && $7==0 && $8==0)' TE_filtered.bed > TE_fil1.bed

#To filter for rows which are upregulated only.
awk 'NR>1 && ($7+$8) > ($5+$6)' TE_fil1.bed > TE_fil2.bed

#sorts the file based on column lines1-4 and 9-10,removes duplicates from file TE_fil2.bed
sort -k1,4 -k9,12 TE_fil2.bed | uniq > TE_fil3.bed

#remove the duplicates after taking combination of columns 1,2,3,4,13.
awk '!seen[$1,$2,$3,$4,$13]++' TE_fil3.bed> TTE_fil4.bed

#reads the file, and prints the first occurence of TE+gene name that is present in file to know for unique TE-gene combintations only.
awk '{
  score=$7+$8;#score I took adding values of count for GSK_rep1+GSK_rep2
  key=$4 FS $12;# this line is to get key of TE+gene(4th column is TE and 12th column is for gene)
  if(!(key in best) || score > best[key]) {
      best[key]=score;
      row[key]=$0;
      order[key]=NR   #if multiple family-gene of  same names are present, then takes whichever has the higher score
  }
}
END {

  for(k in row) print row[k]#prints first occurrence
}' OFS="\t" TTE_fil4.bed > TTE_fil5.bed

#sorting the files based on chr numbers.
sort -k1,1V -k2,2n TTE_fil5.bed > TTE_fil5_sorted.bed

#To add column names to the file
echo -e "TE_chr\tTE_start\tTE_end\tTE_name\tDMSO_rep1\tDMSO_rep2\tGSK_rep1\tGSK_rep2\tGene_chr\tGene_start\tGene_end\tGene_id"     | cat - TTE_fil5_sorted.bed > TTE_fil5_sorted_h.bed

#To print the count for how many unique TE-gene pair are present for each family.
for name in HERVH-int/LTR/ERV1 HERVL74-int/LTR/ERVL MER47C/DNA/TcMar-Tigger MER65C/LTR/ERV1 MER66B/LTR/ERV1 MER92D/LTR/ERV1 CER/Satellite/Satellite
do
    echo -n "$name: "
    grep -w "$name" TTE_fil5_sorted.bed | wc -l
done